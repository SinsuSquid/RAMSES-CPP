&run_params
    hydro = .true.
    nremap = 1
    ncontrol = 1
    nsubcycle = 1, 1, 1, 1, 2
/

&amr_params
    levelmin = 5
    levelmax = 5
    ngridmax = 2000000
    nexpand = 1
    boxlen = 1
/

&init_params
    nregion = 1
    region_type(1) = 'square'
    x_center = 0.5
    y_center = 0.5
    z_center = 0.5
    length_x = 10.0
    length_y = 10.0
    length_z = 10.0
    exp_region = 10.0
    d_region = 1.0
    u_region = 0.0
    v_region = 0.0
    w_region = 0.0
    p_region = 1.0
    a_region = 0.0
    b_region = 0.0
    c_region = 0.001
/

&output_params
    noutput = 1
    tout = 5.0
/

&hydro_params
    gamma = 1.6666667
    courant_factor = 0.8
    slope_type = 2
    riemann = 'upwind'
    riemann2d = 'upwind'
    scheme = 'induction'
    eta_mag = 0.001
/

&refine_params
    err_grad_b2 = 0.1
    interpol_var = 0
    interpol_type = 2
/
