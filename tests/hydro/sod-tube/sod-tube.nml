&run_params
    hydro = .true.
    nsubcycle = 1, 1, 1, 2
    ncontrol = 100
/

&amr_params
    levelmin = 3
    levelmax = 10
    ngridmax = 2000
    nparttot = 1
    nexpand = 1
    boxlen = 1.0
/

&boundary_params
    nboundary = 2
    ibound_min = -1, 1
    ibound_max = -1, 1
    bound_type = 1, 1
/

&init_params
    nregion = 2
    region_type(1:2) = 'square', 'square'
    x_center = 0.25, 0.75
    length_x = 0.5, 0.5
    d_region = 1.0, 0.125
    u_region = 0.0, 0.0
    p_region = 1.0, 0.1
/

&output_params
    noutput = 1
    tout = 0.245
    output_to_log = .false.
/

&hydro_params
    gamma = 1.4
    courant_factor = 0.5
    slope_type = 2
    riemann = 'hllc'
/

&refine_params
    err_grad_d = 0.05
    err_grad_u = 0.05
    err_grad_p = 0.05
    interpol_var = 2
    interpol_type = 0
/
