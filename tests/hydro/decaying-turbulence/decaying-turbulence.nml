This is the RAMSES parameter file for the isothermal decaying turbulence test.

&RUN_PARAMS
hydro=.true.
/

&AMR_PARAMS
levelmin=6
levelmax=6
ngridmax=500000
boxlen=4
/

&HYDRO_PARAMS
gamma=1.4
courant_factor=0.8
scheme='muscl'
slope_type=1
riemann='hllc'
pressure_fix=.true.
beta_fix=0.5
/

&INIT_PARAMS
! set uniform density and pressure
nregion=1
region_type='square'
x_center=2
y_center=2
z_center=2
length_x=4
length_y=4
length_z=4
exp_region=10
d_region=0.28954719470909174
p_region=0.030361026190591216
! set turbulent velocity field
filetype='grafic'
initfile(1)='ic'
/

&OUTPUT_PARAMS
noutput=1
tout=0.25
/

&UNITS_PARAMS
units_density=1.50492957435d-20
units_time=3.1556926d13
units_length=3.0857d18
/

&COOLING_PARAMS
barotropic_eos=.true.
barotropic_eos_form='isothermal'
T_eos=10
mu_gas=2.37
/
